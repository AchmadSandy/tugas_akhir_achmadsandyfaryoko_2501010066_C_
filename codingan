# -------------------------------------------------------------------------
# STRUCTURE DATA & DSS LAYER (Menggunakan Directed Graph & BFS)
# -------------------------------------------------------------------------
class WisataDSSGraph:
    def __init__(self):
        # Menggunakan Adjacency List untuk representasi Directed Graph [cite: 49, 52]
        self.adjacency_list = {}
        # Menyimpan metadata node untuk proses rekomendasi DSS [cite: 17, 98]
        self.node_metadata = {}

    def add_node(self, name, category, budget, rating):
        """Menambahkan Node (Tempat Wisata/Titik Transit) beserta bobot kriteria [cite: 68, 98]"""
        if name not in self.adjacency_list:
            self.adjacency_list[name] = []
            self.node_metadata[name] = {
                "category": category, # Alam, Kuliner, Budaya, Sejarah
                "budget": budget,     # Murah, Sedang, Mahal
                "rating": rating      # Skala 1.0 - 5.0 [cite: 146]
            }

    def add_edge(self, source, destination):
        """Menambahkan Edge (Rute Berarah / Directed Edge) [cite: 52, 68, 98]"""
        if source in self.adjacency_list and destination in self.adjacency_list:
            if destination not in self.adjacency_list[source]:
                self.adjacency_list[source].append(destination)

    def bfs_search_routes(self, start_node, target_category, target_budget):
        """
        Algoritma Utama: Breadth-First Search (BFS) [cite: 55, 57]
        Mencari semua jalur alternatif dan melakukan proses perhitungan filter DSS [cite: 14, 71]
        """
        queue = deque([[start_node]])
        all_paths = []
        recommendations = []
        process_log = [] # Untuk menampilkan proses perhitungan/tracking algoritma 

        process_log.append(f"Memulai pencarian BFS dari titik awal: {start_node}")

        while queue:
            path = queue.popleft()
            current_node = path[-1]

            process_log.append(f"Mengunjungi Node: {current_node} | Jalur saat ini: {' -> '.join(path)}")

            # Cek kriteria DSS untuk node saat ini 
            meta = self.node_metadata[current_node]
            if meta["category"] == target_category and meta["budget"] == target_budget:
                if current_node not in [rec['node'] for rec in recommendations]:
                    recommendations.append({
                        "node": current_node,
                        "path": " -> ".join(path),
                        "score": meta["rating"] # Basis optimasi keputusan berdasarkan rating tertinggi [cite: 16, 17]
                    })

            # Ambil tetangga (Directed) 
            neighbors = self.adjacency_list.get(current_node, [])
            for neighbor in neighbors:
                if neighbor not in path: # Menghindari cyclic loop dalam rute pencarian
                    new_path = list(path)
                    new_path.append(neighbor)
                    queue.append(new_path)
                    all_paths.append(new_path)

        # Mengurutkan rekomendasi keputusan berdasarkan score/rating tertinggi (Fungsi Optimasi DSS) [cite: 16, 17]
        recommendations = sorted(recommendations, key=lambda x: x['score'], reverse=True)
        
        return recommendations, process_log, all_paths

