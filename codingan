# Layout Utama: Dibagi menjadi 2 Kolom (Visualisasi & Pengambilan Keputusan)
col1, col2 = strl.columns([1, 1])

with col1:
    strl.header("📊 Visualisasi Interaktif Real-Time [cite: 69, 131]")
    
    # Mengonversi adjacency list internal ke NetworkX untuk visualisasi Matplotlib [cite: 49]
    G = nx.DiGraph() # DiGraph = Directed Graph 
    
    for node, metadata in current_graph.node_metadata.items():
        G.add_node(node, **metadata)
        
    for source, targets in current_graph.adjacency_list.items():
        for target in targets:
            G.add_edge(source, target)
            
    fig, ax = plt.subplots(figsize=(7, 6))
    pos = nx.spring_layout(G, seed=42)
    
    # Menggambar graph secara visual
    nx.draw_networkx_nodes(G, pos, node_size=1600, node_color='#4A90E2', ax=ax)
    nx.draw_networkx_edges(G, pos, width=2, arrowstyle='->', arrowsize=20, edge_color='#888888', ax=ax)
    nx.draw_networkx_labels(G, pos, font_size=9, font_weight='bold', font_color='black', ax=ax)
    
    plt.title("Peta Rute Perjalanan Berarah (Directed Graph) ", fontsize=12)
    plt.axis('off')
    strl.pyplot(fig)

